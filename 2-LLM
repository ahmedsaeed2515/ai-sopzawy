from abc import ABC, abstractmethod
from dataclasses import dataclass, field
from typing import Any
import time

@dataclass
class ModelMetrics:
    model_id: str
    provider: str
    
    # Timing
    time_to_first_token: float = 0.0    # seconds until response starts
    total_response_time: float = 0.0    # total seconds
    
    # Tokens
    input_tokens: int = 0
    output_tokens: int = 0
    total_tokens: int = 0
    tokens_per_second: float = 0.0
    
    # RAG
    rag_results_count: int = 0
    rag_search_time: float = 0.0
    context_length_chars: int = 0
    
    # Response
    response_text: str = ""
    response_length_chars: int = 0
    response_length_words: int = 0
    
    # Quality scores (0-10)
    relevance_score: float = 0.0        # Did it answer the question?
    accuracy_score: float = 0.0         # Are product details correct?
    arabic_quality_score: float = 0.0  # Quality of Arabic language
    hallucination_detected: bool = False # Did it invent products?
    
    # Status
    success: bool = True
    error_message: str = ""
    
    # Images from RAG
    product_images: list[str] = field(default_factory=list)
    
    # Raw API response (for debugging)
    raw_response: dict = field(default_factory=dict)


class BaseModel(ABC):
    def __init__(self, model_id: str, provider: str, api_key: str):
        self.model_id = model_id
        self.provider = provider
        self.api_key = api_key
    
    @abstractmethod
    async def generate(self, prompt: str, context: str, history: list) -> ModelMetrics:
        """Generate response and return full metrics"""
        pass
    
    def build_messages(self, system_prompt: str, context: str, 
                       user_query: str, history: list) -> list:
        """Build message array for chat completion"""
        messages = [{"role": "system", "content": system_prompt}]
        for msg in history[-4:]:  # last 2 exchanges
            messages.append(msg)
        messages.append({
            "role": "user", 
            "content": f"Context from product database:\n{context}\n\nCustomer question: {user_query}"
        })
        return messages
```

