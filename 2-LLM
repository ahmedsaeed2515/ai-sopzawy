            "hallucination_detected": self._detect_hallucination(response, rag_products),
            "has_price": self._mentions_price(response),
            "has_stock_info": self._mentions_stock(response),
            "response_sentiment": self._analyze_sentiment(response),
            "call_to_action_present": self._has_cta(response),
            "word_count": len(response.split()),
            "conciseness_score": self._score_conciseness(response),
        }
    
    def _score_relevance(self, response: str, query: str) -> float:
        # Check if response addresses the query keywords
        query_keywords = set(query.lower().split())
        response_lower = response.lower()
        matches = sum(1 for kw in query_keywords if kw in response_lower)
        return min(10.0, (matches / max(len(query_keywords), 1)) * 10)
    
    def _score_accuracy(self, response: str, rag_products: list) -> float:
