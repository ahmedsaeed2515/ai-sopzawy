## STEP 5 — PARALLEL BENCHMARK RUNNER

Create `backend/benchmark/runner.py`:

```python
import asyncio
import time
from typing import AsyncIterator

class BenchmarkRunner:
    def __init__(self, models: list, rag_adapter):
        self.models = models
        self.rag = rag_adapter
    
    async def run_comparison(
        self, 
        query: str,
        session_id: str
    ) -> AsyncIterator[dict]:
        """
        Runs all models in parallel, yields results as they complete.
        Uses asyncio.gather() for true parallelism.
        """
        
        # Step 1: Search RAG once, share results with all models
        rag_results = self.rag.search(query, top_k=5)
        context = self.rag.build_context_string(rag_results)
        
        yield {
            "event": "rag_complete",
            "data": {
                "search_time": rag_results["search_time"],
                "results_count": rag_results["results_count"],
                "images": rag_results["images"],
                "session_id": session_id
            }
        }
        
        # Step 2: Run all models simultaneously
        tasks = [
            model.generate(
                prompt=query,
                context=context,
                history=[]
            )
            for model in self.models
        ]
        
        # Yield results as each model completes (not waiting for all)
        for coro in asyncio.as_completed(tasks):
            metrics = await coro
            metrics.rag_results_count = rag_results["results_count"]
            metrics.rag_search_time = rag_results["search_time"]
            metrics.context_length_chars = len(context)
            metrics.product_images = rag_results["images"]
            
            yield {
                "event": "model_complete",
                "data": metrics.__dict__,
                "session_id": session_id
            }
```

